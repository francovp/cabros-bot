# ============================================================================
# Cabros Crypto Bot - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# See README.md for detailed configuration guide
# ============================================================================

# ============================================================================
# REQUIRED: Core Bot Configuration
# ============================================================================

# Telegram bot token (get from BotFather on Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat ID where bot sends alerts (use /start to find your chat ID)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Enable Telegram bot (true or false)
ENABLE_TELEGRAM_BOT=true

# ============================================================================
# OPTIONAL: WhatsApp Alerts (GreenAPI Integration)
# ============================================================================

# Enable WhatsApp alerts (default: false)
ENABLE_WHATSAPP_ALERTS=false

# GreenAPI endpoint URL (e.g., https://xxxx.api.green-api.com/<instance-id>/)
WHATSAPP_API_URL=your_whatsapp_api_url

# GreenAPI API key for authentication
WHATSAPP_API_KEY=your_whatsapp_api_key

# WhatsApp chat/group ID (format: 120363xxxxx@g.us)
WHATSAPP_CHAT_ID=your_whatsapp_chat_id_here

# ============================================================================
# OPTIONAL: AI Grounding (Gemini GoogleSearch Enrichment)
# ============================================================================

# Enable Gemini-based alert enrichment (default: false)
ENABLE_GEMINI_GROUNDING=false

# Google API key with Generative AI enabled (get from Google AI Studio)
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Enable model metadata footer in enriched alerts (default: true)
ENABLE_MESSAGE_FOOTER_METADATA=true

# ==========================================================================
# OPTIONAL: Langfuse Prompt Management
# ==========================================================================

# Fetch runtime prompts from Langfuse instead of local defaults (default: false)
ENABLE_LANGFUSE_PROMPTS=false

# Langfuse project credentials (required when ENABLE_LANGFUSE_PROMPTS=true)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse region or self-hosted base URL (default: https://cloud.langfuse.com)
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Prompt label to fetch (default: latest in dev/test, production in prod-like envs)
LANGFUSE_PROMPT_LABEL=latest

# SDK cache TTL in seconds for prompt fetches (default: 0 for latest, 60 for production)
LANGFUSE_PROMPT_CACHE_TTL_SECONDS=0

# ============================================================================
# OPTIONAL: TradingView MCP Enrichment (Webhook Signals)
# ============================================================================

# Enable MCP-based technical enrichment for TradingView-like alerts
# Example input: BTCUSDT(240) pasó a señal de VENTA
# Runtime note: request must include /api/webhook/alert?useTradingViewData=true
ENABLE_TRADINGVIEW_MCP_ENRICHMENT=false

# MCP server endpoint (Streamable HTTP)
TRADINGVIEW_MCP_URL=https://tradingview-mcp.onrender.com/mcp

# Request timeout per MCP call in milliseconds
TRADINGVIEW_MCP_TIMEOUT_MS=12000

# Retry attempts for MCP calls
TRADINGVIEW_MCP_MAX_RETRIES=3

# Defaults used when signal does not include exchange/timeframe
TRADINGVIEW_MCP_DEFAULT_EXCHANGE=BINANCE
TRADINGVIEW_MCP_DEFAULT_TIMEFRAME=1h

# ============================================================================
# OPTIONAL: Admin Notifications
# ============================================================================

# Chat ID for admin notifications and deployment alerts (optional)
TELEGRAM_ADMIN_NOTIFICATIONS_CHAT_ID=your_admin_chat_id_here

# ============================================================================
# OPTIONAL: Server Configuration
# ============================================================================

# HTTP server port (default: 80)
PORT=80

# Log level for console output (debug, info, warn, error, silent)
# Defaults to debug in development and info in production
LOG_LEVEL=info

# Render.com deployment flag (set automatically by Render)
RENDER=false

# Render preview environment flag (set automatically by Render)
IS_PULL_REQUEST=false

# ============================================================================
# OPTIONAL: News Monitoring Feature (003-news-monitor)
# ============================================================================

# Enable news monitoring endpoint (default: false)
ENABLE_NEWS_MONITOR=false

# Enable news monitoring endpoint in test mode (default: false)
# In test mode, alerts are generated without real news data
ENABLE_NEWS_MONITOR_TEST_MODE=false

# Default crypto symbols if not provided in request (comma-separated)
# Example: BTCUSDT,ETHUSD,BNBUSDT
NEWS_SYMBOLS_CRYPTO=BTCUSDT,ETHUSD,BNBUSDT

# Default stock symbols if not provided in request (comma-separated)
# Example: NVDA,MSFT,AAPL
NEWS_SYMBOLS_STOCKS=NVDA,MSFT,AAPL

# Confidence score threshold for sending alerts (default: 0.7, range: 0.0-1.0)
# Alerts with confidence below this threshold are filtered out
NEWS_ALERT_THRESHOLD=0.7

# Cache time-to-live for deduplication (default: 6 hours)
# Same (symbol, event_category) pair within TTL will be cached
NEWS_CACHE_TTL_HOURS=6

# Per-symbol analysis timeout in milliseconds (default: 30000 ms)
# Each symbol has up to this long to complete analysis
NEWS_TIMEOUT_MS=30000

# ============================================================================
# OPTIONAL: Binance Price Integration (News Monitoring)
# ============================================================================

# Enable Binance crypto price fetching (default: false)
# When enabled, fetches real-time prices from Binance API (~5s timeout)
# Falls back to Gemini GoogleSearch if Binance fails or times out
ENABLE_BINANCE_PRICE_CHECK=false

# ============================================================================
# OPTIONAL: Secondary LLM Enrichment (News Monitoring)
# ============================================================================

# Enable optional secondary LLM enrichment for news alerts (default: false)
# Refines confidence scores using conservative strategy: min(Gemini, LLM)
# Prevents false positives from LLM hallucination
ENABLE_LLM_ALERT_ENRICHMENT=false

# Azure AI Inference endpoint URL
# Example: https://models.github.ai/inference or https://your-azure-instance.inference.ai.azure.com
AZURE_LLM_ENDPOINT=your_azure_or_github_models_endpoint_here

# Azure AI Inference API key
# Use Azure API key or GitHub Personal Access Token (PAT)
AZURE_LLM_KEY=your_azure_api_key_or_github_pat_here

# Azure AI LLM model deployment name
# Example: openai/gpt-5-mini (GitHub Models) or gpt-4o (Azure)
AZURE_LLM_MODEL=your_model_name_here

# ============================================================================
# URL Shortening for WhatsApp (Optional - requires API key for selected service)
# ============================================================================
URL_SHORTENER_SERVICE=bitly
BITLY_ACCESS_TOKEN=
TINYURL_API_KEY=
PICSEE_API_KEY=
REURL_API_KEY=
CUTTLY_API_KEY=
PIXNET0RZ_API_KEY=

# ============================================================================
# OPTIONAL: TradingView Market Scanner Alerts
# ============================================================================

# Enable TradingView Market Scanner endpoint (default: false)
ENABLE_MARKET_SCANNER=false

# Default exchange when not provided in request
MARKET_SCANNER_DEFAULT_EXCHANGE=BINANCE

# Timeout in milliseconds for scanner webhook process (default: 90000, max: 120000)
MARKET_SCANNER_TIMEOUT_MS=90000

# ============================================================================
# Sentry Monitoring Configuration (Optional)
# ============================================================================
ENABLE_SENTRY=false # Enable Sentry error reporting (`true` or `false`, default: `false`)
SENTRY_DSN=your_sentry_dsn_here # Sentry Data Source Name (DSN) from your Sentry project settings
SENTRY_SEND_ALERT_CONTENT=true # Include alert text in error events (`true` or `false`, default: `true`)
SENTRY_SAMPLE_RATE_ERRORS=1.0 # Error sample rate from 0.0 to 1.0 (default: `1.0` = 100% of errors)
SENTRY_TRACES_SAMPLE_RATE=0.1 # Trace sample rate from 0.0 to 1.0 (leave empty/unset to disable tracing entirely)
SENTRY_CONSOLE_LOG_LEVELS=warn,error # Comma-separated console levels captured as Sentry Logs
SENTRY_ENVIRONMENT=development # Explicit environment tag (`production`, `preview`, `development`). Auto-derived if not set
SENTRY_RELEASE=local # Explicit release tag (e.g., `v1.2.3`). Auto-derived from git commit if not set
# ============================================================================

# ============================================================================
# OPTIONAL: Firestore Alert Storage (006-firestore-alert-storage)
# ============================================================================

# Enable storing every /api/webhook/alert payload in Cloud Firestore (default: false)
# When enabled, each alert is persisted to the `alerts` collection after delivery.
# Failure to write to Firestore never blocks or fails alert delivery (fail-open).
ENABLE_FIRESTORE_ALERT_STORAGE=false

# Firebase project ID (optional if already embedded in the service account JSON)
FIREBASE_PROJECT_ID=your_firebase_project_id

# --- Credential Option A: file path (good for local dev / VMs) ---
# Set this to the absolute path of your service account JSON key file.
# The firebase-admin SDK picks this up automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# --- Credential Option B: inline JSON (preferred for Render.com secret env vars) ---
# Paste the entire contents of your service account JSON key as a single-line string.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# ============================================================================
