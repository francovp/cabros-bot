// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: alerts
// Document ID: auto-generated by Firestore Admin SDK
// Fields:
//   - receivedAt:     timestamp  (required) - server timestamp when alert was received
//   - text:           string     (required, max 20000 chars) - original alert text
//   - enriched:       bool       (required) - whether enrichment ran
//   - enrichmentData: map | null (optional) - Gemini/TradingView enriched object
//   - tokenUsage:     map | null (optional) - token usage breakdown
//   - deliveryResults: list      (required) - per-channel SendResult objects
//   - source:         string     (required) - always "webhook"
//   - useTradingViewData: bool   (required) - request query flag
//
// Access pattern: server-side Admin SDK writes only. No client SDK used.
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All writes are performed exclusively by the firebase-admin SDK on the server.
    // The Admin SDK bypasses security rules, so these rules only guard against
    // any accidental client-side access. Deny everything at the client level.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
